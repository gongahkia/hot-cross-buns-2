{
  "name": "hot-cross-buns-2",
  "version": "0.0.0",
  "private": true,
  "description": "Electron-first rebuild of Hot Cross Buns.",
  "author": "gongahkia",
  "main": "out/main/index.js",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "build:release:mac": "HCB_BUILD_COMMIT=$(git rev-parse --short=12 HEAD 2>/dev/null || echo unknown) HCB_BUILD_DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ) HCB_PACKAGE_TOOL=electron-builder pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:smoke": "pnpm build && playwright test -c playwright.config.ts",
    "test:perf": "tsx scripts/perf-smoke.ts",
    "release:review-bundle": "tsx scripts/review-bundle.ts",
    "release:mac-artifacts": "tsx scripts/mac-preview-artifacts.ts",
    "release:checksums": "tsx scripts/release-checksums.ts",
    "release:smoke-dmg": "scripts/smoke-test-dmg.sh release",
    "pack:mac:preview": "pnpm build:release:mac && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --publish never && pnpm release:mac-artifacts && pnpm release:checksums",
    "release:mac:preview": "pnpm test && pnpm build:release:mac && pnpm release:review-bundle && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --publish never && pnpm release:mac-artifacts && pnpm release:checksums"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.20",
    "better-sqlite3": "^12.10.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
